<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MyApp1"
             x:Class="MyApp1.CuttingSavedReportPage"
             x:Name="thisPage"
             Title="Сохраненный отчет"
             BackgroundColor="#F7F2FA">

    <ContentPage.Resources>
        <local:SavedAreaConverter x:Key="SavedAreaConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="15">

                <Label Text="АРХИВНЫЙ РАСЧЕТ" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       TextColor="#312E35"/>

                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="True" BorderColor="Transparent" Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Параметры из архива" TextColor="#6750A4" FontAttributes="Bold" FontSize="16"/>
                        <BoxView HeightRequest="1" Color="#E6E0E9"/>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Размер листа (мм)" TextColor="#49454F"/>
                            <HorizontalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{Binding SavedReport.SheetLength}" FontAttributes="Bold" TextColor="#1C1B1F"/>
                                <Label Text="x" TextColor="#1C1B1F"/>
                                <Label Text="{Binding SavedReport.SheetWidth}" FontAttributes="Bold" TextColor="#1C1B1F"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Площадь листа" TextColor="#49454F"/>
                            <Label Grid.Column="1" 
                                   Text="{Binding SavedReport.SheetArea, Converter={StaticResource SavedAreaConverter}, StringFormat='{0:F2} м²'}" 
                                   FontAttributes="Bold" TextColor="#1C1B1F"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F3EDF7" Margin="0,5"/>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Было использовано листов" TextColor="#49454F"/>
                            <Label Grid.Column="1" Text="{Binding SavedReport.TotalSheets}" 
                                   FontAttributes="Bold" TextColor="#6750A4" FontSize="16"/>
                        </Grid>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Общая площадь материала" TextColor="#49454F"/>
                            <Label Grid.Column="1" 
                                   Text="{Binding SavedReport.TotalSheetArea, Converter={StaticResource SavedAreaConverter}, StringFormat='{0:F2} м²'}" 
                                   FontAttributes="Bold" TextColor="#1C1B1F"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F3EDF7" Margin="0,5"/>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Количество деталей" TextColor="#49454F"/>
                            <Label Grid.Column="1" Text="{Binding SavedReport.TotalPartsCount}" 
                                   FontAttributes="Bold" TextColor="#1C1B1F"/>
                        </Grid>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Площадь деталей" TextColor="#49454F"/>
                            <Label Grid.Column="1" 
                                   Text="{Binding SavedReport.TotalPartsArea, Converter={StaticResource SavedAreaConverter}, StringFormat='{0:F2} м²'}" 
                                   FontAttributes="Bold" TextColor="#1C1B1F"/>
                        </Grid>
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Площадь деталей" TextColor="#49454F"/>
                            <Label Grid.Column="1" 
                                   Text="{Binding SavedReport.TotalPartsArea, Converter={StaticResource SavedAreaConverter}, StringFormat='{0:F2} м²'}" 
                                   FontAttributes="Bold" TextColor="#1C1B1F"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F3EDF7" Margin="0,5"/>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Цвет материала" TextColor="#49454F"/>
                            <Label Grid.Column="1" 
                                   Text="{Binding SavedReport.MaterialColor}" 
                                   FontAttributes="Bold" 
                                   TextColor="#6750A4"
                                   HorizontalTextAlignment="End"/>
                        </Grid>

                    </VerticalStackLayout>
                </Frame>

                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="True" BorderColor="Transparent" Padding="15">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Кромка" TextColor="#6750A4" FontAttributes="Bold" FontSize="16"/>
                        <BoxView HeightRequest="1" Color="#E6E0E9"/>

                        <Grid ColumnDefinitions="*, Auto">
                           
                            <Label Grid.Column="0" Text="{Binding SavedReport.Edge1Thickness, StringFormat='{0} мм'}" 
                                   TextColor="#1C1B1F"  VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding SavedReport.TotalEdge1, StringFormat='{0:F1} м'}" 
                                   TextColor="#6750A4" FontAttributes="Bold" FontSize="15" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F3EDF7"/>

                        <Grid ColumnDefinitions="*, Auto">
                            
                            <Label Grid.Column="0" Text="{Binding SavedReport.Edge2Thickness, StringFormat='{0} мм'}" 
                                   TextColor="#1C1B1F"  VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding SavedReport.TotalEdge2, StringFormat='{0:F1} м'}" 
                                   TextColor="#6750A4" FontAttributes="Bold" FontSize="15" VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>


                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="True" BorderColor="Transparent" Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Список деталей" TextColor="#6750A4" FontAttributes="Bold" FontSize="16"/>

                        <Grid ColumnDefinitions="40, *, *, Auto, 60" Padding="0,0,0,5">
                            <Label Grid.Column="0" Text="№" FontAttributes="Bold" TextColor="#49454F" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="1" Text="Длина" FontAttributes="Bold" TextColor="#49454F" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="2" Text="Ширина" FontAttributes="Bold" TextColor="#49454F" HorizontalTextAlignment="Center"/>

                            <Label Grid.Column="3" Text="Цвет" FontAttributes="Bold" TextColor="#49454F" HorizontalTextAlignment="Center"
                                   IsVisible="{Binding IsSavedColorVisible, Source={x:Reference thisPage}}"/>

                            <Label Grid.Column="4" Text="Кол." FontAttributes="Bold" TextColor="#49454F" HorizontalTextAlignment="Center"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#E6E0E9" Margin="0,0,0,5"/>

                        <CollectionView ItemsSource="{Binding SavedReport.Details}" HeightRequest="300">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="40, *, *, Auto, 60" Padding="0,6">

                                        <Label Grid.Column="0" Text="{Binding Id}" VerticalOptions="Start" HorizontalTextAlignment="Center" TextColor="#1C1B1F"/>

                                        <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Start" Margin="5,0">
                                            <Label Text="{Binding Length}" HorizontalTextAlignment="Center" TextColor="#1C1B1F" FontAttributes="Bold" Margin="0,0,0,2"/>

                                            <BoxView HeightRequest="2" Color="Black" IsVisible="{Binding E1L1}" HorizontalOptions="Fill"/>
                                            <BoxView HeightRequest="2" Color="Black" IsVisible="{Binding E1L2}" HorizontalOptions="Fill" Margin="0,1,0,0"/>

                                            <Border HeightRequest="1" Stroke="Black" StrokeThickness="1.5" StrokeDashArray="3,2" 
                                                    IsVisible="{Binding E2L1}" HorizontalOptions="Fill" StrokeShape="Rectangle" Margin="0,1,0,0"/>
                                            <Border HeightRequest="1" Stroke="Black" StrokeThickness="1.5" StrokeDashArray="3,2" 
                                                    IsVisible="{Binding E2L2}" HorizontalOptions="Fill" StrokeShape="Rectangle" Margin="0,1,0,0"/>
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Grid.Column="2" Spacing="0" VerticalOptions="Start" Margin="5,0">
                                            <Label Text="{Binding Width}" HorizontalTextAlignment="Center" TextColor="#1C1B1F" FontAttributes="Bold" Margin="0,0,0,2"/>

                                            <BoxView HeightRequest="2" Color="Black" IsVisible="{Binding E1W1}" HorizontalOptions="Fill"/>
                                            <BoxView HeightRequest="2" Color="Black" IsVisible="{Binding E1W2}" HorizontalOptions="Fill" Margin="0,1,0,0"/>

                                            <Border HeightRequest="1" Stroke="Black" StrokeThickness="1.5" StrokeDashArray="3,2" 
                                                    IsVisible="{Binding E2W1}" HorizontalOptions="Fill" StrokeShape="Rectangle" Margin="0,1,0,0"/>
                                            <Border HeightRequest="1" Stroke="Black" StrokeThickness="1.5" StrokeDashArray="3,2" 
                                                    IsVisible="{Binding E2W2}" HorizontalOptions="Fill" StrokeShape="Rectangle" Margin="0,1,0,0"/>
                                        </VerticalStackLayout>

                                        <Label Grid.Column="3" Text="{Binding Color}" 
                                               VerticalOptions="Start" HorizontalTextAlignment="Center" TextColor="#1C1B1F"
                                               Margin="5,0"
                                               IsVisible="{Binding IsSavedColorVisible, Source={x:Reference thisPage}}"/>

                                        <Label Grid.Column="4" Text="{Binding Count}" VerticalOptions="Start" HorizontalTextAlignment="Center" TextColor="#1C1B1F"/>

                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <VerticalStackLayout x:Name="ReportSheetsContainer" Spacing="15" Padding="0,10,0,0">
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <Frame Grid.Row="1" 
               BackgroundColor="White" 
               Padding="20,15" 
               HasShadow="True" 
               CornerRadius="0"
               BorderColor="#E6E0E9">
            <Button Text="СОХРАНИТЬ PDF" 
                    Clicked="OnSavePdfClicked"
                    BackgroundColor="#6750A4" 
                    TextColor="White" 
                    FontAttributes="Bold"
                    HeightRequest="50"/>
        </Frame>
    </Grid>
</ContentPage>