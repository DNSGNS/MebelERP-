<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MyApp1"
             x:Class="MyApp1.CuttingSettingContentView">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">

            <Label Text="Настройки раскроя" 
                   FontSize="26" 
                   FontAttributes="Bold" 
                   TextColor="#312E35"/>

            <VerticalStackLayout Spacing="15">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <BoxView WidthRequest="4" HeightRequest="20" Color="#6750A4" CornerRadius="2"/>
                    <Label Text="ФОРМАТ ЛИСТА" FontSize="14" TextColor="#6750A4" FontAttributes="Bold"/>
                </HorizontalStackLayout>

                <Frame BackgroundColor="White" HasShadow="False" BorderColor="#CAC4D0" CornerRadius="12" Padding="15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Выберите размер материала" FontSize="12" TextColor="Gray" Margin="5,0"/>
                        <Picker Title="Нажмите для выбора..."
                                ItemsSource="{Binding Settings.AvailableSheetSizes}"
                                SelectedItem="{Binding Settings.SelectedSheetSize}"
                                ItemDisplayBinding="{Binding Name}"
                                TextColor="#1C1B1F"
                                FontAttributes="Bold"/>
                        <BoxView HeightRequest="1" Color="#6750A4"/>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="15">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <BoxView WidthRequest="4" HeightRequest="20" Color="#2B3C51" CornerRadius="2"/>
                    <Label Text="ТЕХНИЧЕСКИЕ ПАРАМЕТРЫ" FontSize="14" TextColor="#2B3C51" FontAttributes="Bold"/>
                </HorizontalStackLayout>

                <Frame BackgroundColor="White" HasShadow="False" BorderColor="#CAC4D0" CornerRadius="12" Padding="15">
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Ширина реза (мм)" FontSize="11" TextColor="#2B3C51" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                            <Entry Text="{Binding Settings.CutWidth}" 
                                   Keyboard="Numeric" 
                                   TextColor="#1C1B1F"
                                   HorizontalTextAlignment="Center"/>
                            <BoxView HeightRequest="1.5" Color="#2B3C51"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Отступ края (мм)" FontSize="11" TextColor="#2B3C51" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                            <Entry Text="{Binding Settings.EdgeOffset}" 
                                   Keyboard="Numeric" 
                                   TextColor="#1C1B1F"
                                   HorizontalTextAlignment="Center"/>
                            <BoxView HeightRequest="1.5" Color="#2B3C51"/>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="15">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <BoxView WidthRequest="4" HeightRequest="20" Color="#2B3C51" CornerRadius="2"/>
                    <Label Text="МЕТОД РАСКРОЯ" FontSize="14" TextColor="#2B3C51" FontAttributes="Bold"/>
                </HorizontalStackLayout>

                <Frame BackgroundColor="White" HasShadow="False" BorderColor="#CAC4D0" CornerRadius="12" Padding="15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Приоритетное направление" FontSize="12" TextColor="Gray" Margin="5,0"/>
                        <Picker ItemsSource="{Binding Settings.CuttingMethods}"
                                SelectedItem="{Binding Settings.CuttingMethod}"
                                TextColor="#1C1B1F"
                                FontAttributes="Bold"/>
                        <BoxView HeightRequest="1" Color="#2B3C51"/>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentView>