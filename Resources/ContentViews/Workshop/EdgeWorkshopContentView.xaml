<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MyApp1"
             x:Class="MyApp1.Resources.ContentViews.Workshop.EdgeWorkshopContentView"
             BackgroundColor="#FBF8FF">

    <ContentView.Resources>
        <ColumnDefinitionCollection x:Key="TableColumns">
            <ColumnDefinition Width="40"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="50"/>
        </ColumnDefinitionCollection>

        <local:EdgeStatusConverter x:Key="EdgeStatusConverter" />
    </ContentView.Resources>

    <Grid RowDefinitions="Auto, *" Padding="10">

        <!-- ===== HEADER ===== -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                <Label Text="ЗАДАЧИ КРОМЛЕНИЯ"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#312E35"/>
                <Label Text="Список деталей для обработки"
                       FontSize="12"
                       TextColor="Gray"/>
            </VerticalStackLayout>

            <Button Grid.Column="1"
                    Text="🔄 Обновить"
                    Clicked="OnRefreshClicked"
                    BackgroundColor="#E8DEF8"
                    TextColor="#1D192B"
                    FontSize="12"
                    HeightRequest="36"
                    CornerRadius="8"/>
        </Grid>

        <!-- ===== TABLE ===== -->
        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Always">

            <Grid RowDefinitions="Auto,*">

                <!-- ===== COLUMN HEADERS ===== -->
                <Border Grid.Row="0"
                        BackgroundColor="#F5F5F5"
                        StrokeThickness="0"
                        Padding="10,8"
                        Margin="0,0,0,5">

                    <Grid ColumnDefinitions="{StaticResource TableColumns}">
                        <Label Grid.Column="0" Text="Тип" FontSize="11" TextColor="Gray" HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="1" Text="Проект / Объект" FontSize="11" TextColor="Gray"/>
                        <Label Grid.Column="2" Text="Дата" FontSize="11" TextColor="Gray" HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="3" Text="Взял" FontSize="11" TextColor="Gray" HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="4" Text="Готов" FontSize="11" TextColor="Gray" HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="5" Text=""/>
                    </Grid>
                </Border>

                <!-- ===== DATA ===== -->
                <CollectionView Grid.Row="1"
                                ItemsSource="{Binding EdgeTasks}"
                                SelectionMode="None">

                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center"
                                             HorizontalOptions="Center"
                                             Spacing="10">
                            <Label Text="📭" FontSize="40" HorizontalTextAlignment="Center"/>
                            <Label Text="Нет задач на кромление"
                                   TextColor="Gray"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Border StrokeThickness="0"
                                        BackgroundColor="White"
                                        Margin="0,0,0,8"
                                        Padding="5,10">

                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>

                                    <Grid ColumnDefinitions="{StaticResource TableColumns}"
                                          VerticalOptions="Center">

                                        <Border Grid.Column="0"
                                                WidthRequest="26"
                                                HeightRequest="26"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"
                                                StrokeThickness="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="13"/>
                                            </Border.StrokeShape>

                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding MaterialType}" Value="Ldsp">
                                                    <Setter Property="BackgroundColor" Value="#E0E0E0"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding MaterialType}" Value="FAgt">
                                                    <Setter Property="BackgroundColor" Value="#FFD8E4"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding MaterialType}" Value="FLdsp">
                                                    <Setter Property="BackgroundColor" Value="#D0BCFF"/>
                                                </DataTrigger>
                                            </Border.Triggers>

                                            <Label FontSize="10"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   TextColor="#49454F">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding MaterialType}" Value="Ldsp">
                                                        <Setter Property="Text" Value="ЛДСП"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding MaterialType}" Value="FAgt">
                                                        <Setter Property="Text" Value="Ф_АГТ"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding MaterialType}" Value="FLdsp">
                                                        <Setter Property="Text" Value="Ф_ЛДСП"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="0"
                                                             VerticalOptions="Center"
                                                             Margin="5,0">
                                            <Label Text="{Binding ProjectName}"
                                                   FontAttributes="Bold"
                                                   FontSize="13"
                                                   TextColor="#1C1B1F"
                                                   LineBreakMode="TailTruncation"/>
                                            <Label Text="{Binding ObjectName}"
                                                   FontSize="11"
                                                   TextColor="Gray"
                                                   LineBreakMode="TailTruncation"/>
                                        </VerticalStackLayout>

                                        <Label Grid.Column="2"
                                               Text="{Binding CreationDate, StringFormat='{0:dd.MM}'}"
                                               FontSize="12"
                                               TextColor="#49454F"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>

                                        <CheckBox Grid.Column="3"
                                                  IsChecked="{Binding IsTaken}"
                                                  CheckedChanged="OnTaskTakenChecked"
                                                  HorizontalOptions="Center"
                                                  VerticalOptions="Center"
                                                  Color="#6750A4"/>

                                        <CheckBox Grid.Column="4"
                                                  IsChecked="{Binding Status, Converter={StaticResource EdgeStatusConverter}}"
                                                  CheckedChanged="OnTaskDoneChecked"
                                                  HorizontalOptions="Center"
                                                  VerticalOptions="Center"
                                                  Color="#2E7D32"/>

                                        <Button Grid.Column="5"
                                                Text="➜"
                                                Clicked="OnOpenReportClicked"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="Transparent"
                                                TextColor="#6750A4"
                                                FontSize="18"
                                                Padding="0"
                                                HeightRequest="30"
                                                WidthRequest="30"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </Grid>
        </ScrollView>
    </Grid>
</ContentView>