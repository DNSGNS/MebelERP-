<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MyApp1"
             x:Class="MyApp1.DoorContentView"
             VerticalOptions="FillAndExpand"
             HorizontalOptions="Fill">

    <ContentView.Resources>
        <local:OtherInsertTypeConverter x:Key="OtherInsertTypeConverter" />
    </ContentView.Resources>

    <ScrollView VerticalOptions="FillAndExpand"
                HorizontalOptions="Fill">

        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Параметры дверей" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   TextColor="#312E35"/>

            <Frame BackgroundColor="White" 
                   HasShadow="False" 
                   BorderColor="#CAC4D0" 
                   CornerRadius="12" 
                   Padding="15">
                <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                    <Label Text="Количество дверей:" 
                           VerticalOptions="Center" 
                           FontAttributes="Bold" 
                           TextColor="#6750A4"/>
                    <Entry x:Name="EntDoorCount"
                           Text="{Binding DoorCount}" 
                           Keyboard="Numeric" 
                           WidthRequest="60" 
                           HorizontalTextAlignment="Center" 
                           Focused="OnEntryFocused"
                           ReturnType="Next"
                           Completed="ToRouterLength"
                           TextColor="#1C1B1F"/>
                </HorizontalStackLayout>
            </Frame>

            <Frame BackgroundColor="White" 
                   BorderColor="#6750A4" 
                   CornerRadius="12" 
                   Padding="15" 
                   HasShadow="False">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Фрезер" 
                           FontAttributes="Bold" 
                           TextColor="#6750A4"/>
                    <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Длина" 
                                   FontSize="11" 
                                   HorizontalTextAlignment="Center" 
                                   TextColor="#6750A4"/>
                            <Entry x:Name="EntRouterLength"
                                   Text="{Binding Router.Length}" 
                                   Keyboard="Numeric" 
                                   HorizontalTextAlignment="Center" 
                                   Focused="OnEntryFocused"
                                   ReturnType="Next"
                                   Completed="ToRouterWidth"
                                   TextColor="#1C1B1F" 
                                   BackgroundColor="Transparent"/>
                            <BoxView HeightRequest="1.5" Color="#6750A4"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Ширина" 
                                   FontSize="11" 
                                   HorizontalTextAlignment="Center" 
                                   TextColor="#6750A4"/>
                            <Entry x:Name="EntRouterWidth"
                                   Text="{Binding Router.Width}" 
                                   Keyboard="Numeric" 
                                   HorizontalTextAlignment="Center" 
                                   Focused="OnEntryFocused"
                                   ReturnType="Next"
                                   Completed="ToRouterCount"
                                   TextColor="#1C1B1F" 
                                   BackgroundColor="Transparent"/>
                            <BoxView HeightRequest="1.5" Color="#6750A4"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2">
                            <Label Text="Кол-во" 
                                   FontSize="11" 
                                   HorizontalTextAlignment="Center" 
                                   TextColor="#6750A4"/>
                            <Entry x:Name="EntRouterCount"
                                   Text="{Binding Router.Count}" 
                                   Keyboard="Numeric" 
                                   HorizontalTextAlignment="Center" 
                                   Focused="OnEntryFocused"
                                   ReturnType="Next"
                                   Completed="ToMirrorLength"
                                   TextColor="#1C1B1F" 
                                   BackgroundColor="Transparent"/>
                            <BoxView HeightRequest="1.5" Color="#6750A4"/>
                        </VerticalStackLayout>
                    </Grid>
                    <Label Text="{Binding Router.Area, StringFormat='Площадь: {0:F3} м²'}" 
                           FontSize="12" 
                           TextColor="Gray" 
                           HorizontalOptions="End"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="White" 
                   BorderColor="#6750A4" 
                   CornerRadius="12" 
                   Padding="15" 
                   HasShadow="False">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Зеркало" 
                           FontAttributes="Bold" 
                           TextColor="#6750A4"/>
                    <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Длина" 
                                   FontSize="11" 
                                   HorizontalTextAlignment="Center" 
                                   TextColor="#6750A4"/>
                            <Entry x:Name="EntMirrorLength"
                                   Text="{Binding Mirror.Length}" 
                                   Keyboard="Numeric" 
                                   HorizontalTextAlignment="Center" 
                                   Focused="OnEntryFocused"
                                   ReturnType="Next"
                                   Completed="ToMirrorWidth"
                                   TextColor="#1C1B1F" 
                                   BackgroundColor="Transparent"/>
                            <BoxView HeightRequest="1.5" Color="#6750A4"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Ширина" 
                                   FontSize="11" 
                                   HorizontalTextAlignment="Center" 
                                   TextColor="#6750A4"/>
                            <Entry x:Name="EntMirrorWidth" Text="{Binding Mirror.Width}" 
                                   Keyboard="Numeric" 
                                   HorizontalTextAlignment="Center" 
                                   Focused="OnEntryFocused"
                                   ReturnType="Next"
                                   Completed="ToMirrorCount"
                                   TextColor="#1C1B1F" 
                                   BackgroundColor="Transparent"/>
                            <BoxView HeightRequest="1.5" Color="#6750A4"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2">
                            <Label Text="Кол-во" 
                                   FontSize="11" 
                                   HorizontalTextAlignment="Center" 
                                   TextColor="#6750A4"/>
                            <Entry x:Name="EntMirrorCount"
                                   Text="{Binding Mirror.Count}" 
                                   Keyboard="Numeric" 
                                   HorizontalTextAlignment="Center" 
                                   Focused="OnEntryFocused"
                                   ReturnType="Next"
                                   Completed="ToLdspLength"
                                   TextColor="#1C1B1F" 
                                   BackgroundColor="Transparent"/>
                            <BoxView HeightRequest="1.5" Color="#6750A4"/>
                        </VerticalStackLayout>
                    </Grid>
                    <Label Text="{Binding Mirror.Area, StringFormat='Площадь: {0:F3} м²'}" 
                           FontSize="12" 
                           TextColor="Gray" 
                           HorizontalOptions="End"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="White" 
                   BorderColor="#6750A4" 
                   CornerRadius="12" 
                   Padding="15" 
                   HasShadow="False">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Вставка ДСП" 
                           FontAttributes="Bold" 
                           TextColor="#6750A4"/>
                    <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Длина" 
                                   FontSize="11" 
                                   HorizontalTextAlignment="Center" 
                                   TextColor="#6750A4"/>
                            <Entry x:Name="EntLdspLength"
                                   Text="{Binding Ldsp.Length}" 
                                   Keyboard="Numeric" 
                                   HorizontalTextAlignment="Center" 
                                   Focused="OnEntryFocused"
                                   ReturnType="Next"
                                   Completed="ToLdspWidth"
                                   TextColor="#1C1B1F" 
                                   BackgroundColor="Transparent"/>
                            <BoxView HeightRequest="1.5" Color="#6750A4"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label
                                   Text="Ширина" 
                                   FontSize="11" 
                                   HorizontalTextAlignment="Center" 
                                   TextColor="#6750A4"/>
                            <Entry x:Name="EntLdspWidth"
                                   Text="{Binding Ldsp.Width}" 
                                   Keyboard="Numeric" 
                                   HorizontalTextAlignment="Center" 
                                   Focused="OnEntryFocused"
                                   ReturnType="Next"
                                   Completed="ToLdspCount"
                                   TextColor="#1C1B1F" 
                                   BackgroundColor="Transparent"/>
                            <BoxView HeightRequest="1.5" Color="#6750A4"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2">
                            <Label Text="Кол-во" 
                                   FontSize="11" 
                                   HorizontalTextAlignment="Center" 
                                   TextColor="#6750A4"/>
                            <Entry x:Name="EntLdspCount"
                                   Text="{Binding Ldsp.Count}" 
                                   Keyboard="Numeric" 
                                   HorizontalTextAlignment="Center" 
                                   Focused="OnEntryFocused"
                                   ReturnType="Next"
                                   Completed="ToOtherLength"
                                   TextColor="#1C1B1F" 
                                   BackgroundColor="Transparent"/>
                            <BoxView HeightRequest="1.5" Color="#6750A4"/>
                        </VerticalStackLayout>
                    </Grid>
                    <Label Text="{Binding Ldsp.Area, StringFormat='Площадь: {0:F3} м²'}" 
                           FontSize="12" 
                           TextColor="Gray" 
                           HorizontalOptions="End"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="White" 
                   BorderColor="#2B3C51" 
                   CornerRadius="12" 
                   Padding="15" 
                   HasShadow="False">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Другие вставки" 
                           FontAttributes="Bold" 
                           TextColor="#2B3C51"/>

                    <Picker Title="Выберите тип" 
                            ItemsSource="{Binding Other.Types}" 
                            SelectedItem="{Binding Other.SelectedType}"
                            ItemDisplayBinding="{Binding ., Converter={StaticResource OtherInsertTypeConverter}}"
                            TextColor="#2B3C51" 
                            FontAttributes="Bold"/>
                    <BoxView HeightRequest="1" Color="#2B3C51" Margin="0,0,0,5"/>

                    <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Длина" 
                                   FontSize="11" 
                                   HorizontalTextAlignment="Center" 
                                   TextColor="#2B3C51"/>
                            <Entry x:Name="EntOtherLength"
                                   Text="{Binding Other.Length}" 
                                   Keyboard="Numeric" 
                                   HorizontalTextAlignment="Center" 
                                   Focused="OnEntryFocused"
                                   ReturnType="Next"
                                   Completed="ToOtherWidth"
                                   TextColor="#1C1B1F" 
                                   BackgroundColor="Transparent"/>
                            <BoxView HeightRequest="1.5" Color="#2B3C51"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Ширина" 
                                   FontSize="11" 
                                   HorizontalTextAlignment="Center" 
                                   TextColor="#2B3C51"/>
                            <Entry x:Name="EntOtherWidth"
                                   Text="{Binding Other.Width}" 
                                   Keyboard="Numeric" 
                                   HorizontalTextAlignment="Center" 
                                   Focused="OnEntryFocused"
                                   ReturnType="Next"
                                   Completed="ToOtherCount"
                                   TextColor="#1C1B1F" 
                                   BackgroundColor="Transparent"/>
                            <BoxView HeightRequest="1.5" Color="#2B3C51"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2">
                            <Label Text="Кол-во" 
                                   FontSize="11" 
                                   HorizontalTextAlignment="Center" 
                                   TextColor="#2B3C51"/>
                            <Entry x:Name="EntOtherCount"
                                   Text="{Binding Other.Count}" 
                                   Keyboard="Numeric" 
                                   HorizontalTextAlignment="Center" 
                                   Focused="OnEntryFocused"
                                   ReturnType="Done"
                                   TextColor="#1C1B1F" 
                                   BackgroundColor="Transparent"/>
                            <BoxView HeightRequest="1.5" Color="#2B3C51"/>
                        </VerticalStackLayout>
                    </Grid>
                    <Label Text="{Binding Other.Area, StringFormat='Площадь: {0:F3} м²'}" 
                           FontSize="12" 
                           TextColor="Gray" 
                           HorizontalOptions="End"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentView>