<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MyApp1"
             x:Class="MyApp1.FurnitureContentView"
             VerticalOptions="FillAndExpand"
             HorizontalOptions="Fill">

    <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="15" BackgroundColor="#FBF8FF">

        <Label Grid.Row="0" 
               Text="Фурнитура" 
               FontSize="24" 
               FontAttributes="Bold" 
               TextColor="#1C1B1F"/>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <Grid ColumnDefinitions="*, 100" Padding="15,0,15,8">
                    <Label Text="НАИМЕНОВАНИЕ" 
                           FontSize="12" 
                           TextColor="#6750A4" 
                           FontAttributes="Bold"/>
                    <Label Grid.Column="1" 
                           Text="КОЛ-ВО" 
                           FontSize="12" 
                           TextColor="#6750A4" 
                           FontAttributes="Bold" 
                           HorizontalTextAlignment="Center"/>
                </Grid>

                <Frame BackgroundColor="White" 
                       HasShadow="False" 
                       BorderColor="#CAC4D0" 
                       CornerRadius="12" 
                       Padding="0">

                    <VerticalStackLayout Spacing="0">

                        <Grid ColumnDefinitions="*, 100" Padding="15,10">
                            <Label Text="ХДФ (м²)" VerticalOptions="Center" FontSize="15" TextColor="#1C1B1F"/>
                            <VerticalStackLayout Grid.Column="1">
                                <Entry x:Name="EntHdf" Text="{Binding Furniture.Hdf}" ReturnType="Next" Completed="ToNaprBez" Keyboard="Numeric" HorizontalTextAlignment="Center" 
                                       TextColor="#1C1B1F" FontSize="16" Focused="OnEntryFocused" HeightRequest="40"/>
                                <BoxView HeightRequest="1" Color="#6750A4" Margin="5,0"/>
                            </VerticalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <Grid ColumnDefinitions="*, 100" Padding="15,10">
                            <Label Text="Направляющие без доводчика" VerticalOptions="Center" FontSize="15" TextColor="#1C1B1F"/>
                            <VerticalStackLayout Grid.Column="1">
                                <Entry x:Name="EntNaprBez" Text="{Binding Furniture.NaprBez}" ReturnType="Next" Completed="ToNaprS" Keyboard="Numeric" HorizontalTextAlignment="Center" 
                                       TextColor="#1C1B1F" FontSize="16" Focused="OnEntryFocused" HeightRequest="40"/>
                                <BoxView HeightRequest="1" Color="#6750A4" Margin="5,0"/>
                            </VerticalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <Grid ColumnDefinitions="*, 100" Padding="15,10">
                            <Label Text="Направляющие с доводчиком" VerticalOptions="Center" FontSize="15" TextColor="#1C1B1F"/>
                            <VerticalStackLayout Grid.Column="1">
                                <Entry x:Name="EntNaprS" Text="{Binding Furniture.NaprS}" ReturnType="Next" Completed="ToPetliBez" Keyboard="Numeric" HorizontalTextAlignment="Center" 
                                       TextColor="#1C1B1F" FontSize="16" Focused="OnEntryFocused" HeightRequest="40"/>
                                <BoxView HeightRequest="1" Color="#6750A4" Margin="5,0"/>
                            </VerticalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <Grid ColumnDefinitions="*, 100" Padding="15,10">
                            <Label Text="Петли без доводчика (шт)" VerticalOptions="Center" FontSize="15" TextColor="#1C1B1F"/>
                            <VerticalStackLayout Grid.Column="1">
                                <Entry x:Name="EntPetliBez" Text="{Binding Furniture.PetliBez}" ReturnType="Next" Completed="ToPetliS" Keyboard="Numeric" HorizontalTextAlignment="Center" 
                                       TextColor="#1C1B1F" FontSize="16" Focused="OnEntryFocused" HeightRequest="40"/>
                                <BoxView HeightRequest="1" Color="#6750A4" Margin="5,0"/>
                            </VerticalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <Grid ColumnDefinitions="*, 100" Padding="15,10">
                            <Label Text="Петли с доводчиком (шт)" VerticalOptions="Center" FontSize="15" TextColor="#1C1B1F"/>
                            <VerticalStackLayout Grid.Column="1">
                                <Entry x:Name="EntPetliS" Text="{Binding Furniture.PetliS}" ReturnType="Next" Completed="ToSkoba" Keyboard="Numeric" HorizontalTextAlignment="Center" 
                                       TextColor="#1C1B1F" FontSize="16" Focused="OnEntryFocused" HeightRequest="40"/>
                                <BoxView HeightRequest="1" Color="#6750A4" Margin="5,0"/>
                            </VerticalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <Grid ColumnDefinitions="*, 100" Padding="15,10">
                            <Label Text="Ручка-скоба (шт)" VerticalOptions="Center" FontSize="15" TextColor="#1C1B1F"/>
                            <VerticalStackLayout Grid.Column="1">
                                <Entry x:Name="EntSkoba" Text="{Binding Furniture.Skoba}" ReturnType="Next" Completed="ToNakladnaya" Keyboard="Numeric" HorizontalTextAlignment="Center" 
                                       TextColor="#1C1B1F" FontSize="16" Focused="OnEntryFocused" HeightRequest="40"/>
                                <BoxView HeightRequest="1" Color="#6750A4" Margin="5,0"/>
                            </VerticalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <Grid ColumnDefinitions="*, 100" Padding="15,10">
                            <Label Text="Ручка накладная (шт)" VerticalOptions="Center" FontSize="15" TextColor="#1C1B1F"/>
                            <VerticalStackLayout Grid.Column="1">
                                <Entry x:Name="EntNakladnaya" Text="{Binding Furniture.Nakladnaya}" ReturnType="Next" Completed="ToKnopka" Keyboard="Numeric" HorizontalTextAlignment="Center" 
                                       TextColor="#1C1B1F" FontSize="16" Focused="OnEntryFocused" HeightRequest="40"/>
                                <BoxView HeightRequest="1" Color="#6750A4" Margin="5,0"/>
                            </VerticalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <Grid ColumnDefinitions="*, 100" Padding="15,10">
                            <Label Text="Ручка-кнопка (шт)" VerticalOptions="Center" FontSize="15" TextColor="#1C1B1F"/>
                            <VerticalStackLayout Grid.Column="1">
                                <Entry x:Name="EntKnopka" Text="{Binding Furniture.Knopka}" ReturnType="Next" Completed="ToGola" Keyboard="Numeric" HorizontalTextAlignment="Center" 
                                       TextColor="#1C1B1F" FontSize="16" Focused="OnEntryFocused" HeightRequest="40"/>
                                <BoxView HeightRequest="1" Color="#6750A4" Margin="5,0"/>
                            </VerticalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <Grid ColumnDefinitions="*, 100" Padding="15,10">
                            <Label Text="Профиль Gola (м)" VerticalOptions="Center" FontSize="15" TextColor="#1C1B1F"/>
                            <VerticalStackLayout Grid.Column="1">
                                <Entry x:Name="EntGola" Text="{Binding Furniture.Gola}" ReturnType="Next" Completed="ToTruba" Keyboard="Numeric" HorizontalTextAlignment="Center" 
                                       TextColor="#1C1B1F" FontSize="16" Focused="OnEntryFocused" HeightRequest="40"/>
                                <BoxView HeightRequest="1" Color="#6750A4" Margin="5,0"/>
                            </VerticalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <Grid ColumnDefinitions="*, 100" Padding="15,10">
                            <Label Text="Труба хром (мп)" VerticalOptions="Center" FontSize="15" TextColor="#1C1B1F"/>
                            <VerticalStackLayout Grid.Column="1">
                                <Entry x:Name="EntTruba" Text="{Binding Furniture.Truba}" ReturnType="Next" Completed="ToGazLift" Keyboard="Numeric" HorizontalTextAlignment="Center" 
                                       TextColor="#1C1B1F" FontSize="16" Focused="OnEntryFocused" HeightRequest="40"/>
                                <BoxView HeightRequest="1" Color="#6750A4" Margin="5,0"/>
                            </VerticalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <Grid ColumnDefinitions="*, 100" Padding="15,10">
                            <Label Text="Газ-лифт (шт)" VerticalOptions="Center" FontSize="15" TextColor="#1C1B1F"/>
                            <VerticalStackLayout Grid.Column="1">
                                <Entry x:Name="EntGazLift" Text="{Binding Furniture.GazLift}" ReturnType="Next" Completed="ToKruchki" Keyboard="Numeric" HorizontalTextAlignment="Center" 
                                       TextColor="#1C1B1F" FontSize="16" Focused="OnEntryFocused" HeightRequest="40"/>
                                <BoxView HeightRequest="1" Color="#6750A4" Margin="5,0"/>
                            </VerticalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <Grid ColumnDefinitions="*, 100" Padding="15,10">
                            <Label Text="Крючки (шт)" VerticalOptions="Center" FontSize="15" TextColor="#1C1B1F"/>
                            <VerticalStackLayout Grid.Column="1">
                                <Entry x:Name="EntKruchki" Text="{Binding Furniture.Kruchki}" ReturnType="Next" Completed="ToPodsvetka" Keyboard="Numeric" HorizontalTextAlignment="Center" 
                                       TextColor="#1C1B1F" FontSize="16" Focused="OnEntryFocused" HeightRequest="40"/>
                                <BoxView HeightRequest="1" Color="#6750A4" Margin="5,0"/>
                            </VerticalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <Grid ColumnDefinitions="*, 100" Padding="15,10">
                            <Label Text="Подсветка (мп)" VerticalOptions="Center" FontSize="15" TextColor="#1C1B1F"/>
                            <VerticalStackLayout Grid.Column="1">
                                <Entry x:Name="EntPodsvetka" Text="{Binding Furniture.Podsvetka}" ReturnType="Done" Keyboard="Numeric" HorizontalTextAlignment="Center" 
                                       TextColor="#1C1B1F" FontSize="16" Focused="OnEntryFocused" HeightRequest="40"/>
                                <BoxView HeightRequest="1" Color="#6750A4" Margin="5,0"/>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#CAC4D0"/>
                        <VerticalStackLayout Padding="0,10">
                            <Label Text="Профили" 
           FontSize="16" 
           TextColor="#6750A4" 
           FontAttributes="Bold" 
           Margin="15,5,15,0"/>
                            <BoxView HeightRequest="1" Color="#F0F0F0" Margin="15,0"/>

                            <Grid ColumnDefinitions="*, 70, 70" Padding="15,5">
                                <Label Text="НАИМЕНОВАНИЕ" FontAttributes="Bold" FontSize="12" TextColor="#6750A4" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="РАЗМЕР" FontAttributes="Bold" FontSize="12" TextColor="#6750A4" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="КОЛ-ВО" FontAttributes="Bold" FontSize="12" TextColor="#6750A4" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                            </Grid>

                            <VerticalStackLayout BindingContext="{Binding Furniture.Profiles[0]}">

                                <Grid ColumnDefinitions="*, 70, 70" Padding="15,8">
                                    <Label Text="{Binding TopGuideName}" FontSize="15" TextColor="#1C1B1F" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding TopGuideSize, StringFormat='{0:F0} мм'}" FontSize="15" TextColor="#1C1B1F" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                    <Label Grid.Column="2" Text="{Binding TopGuideCount}" FontSize="15" TextColor="#1C1B1F" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                </Grid>
                                <BoxView HeightRequest="1" Color="#F0F0F0" Margin="15,0"/>

                                <Grid ColumnDefinitions="*, 70, 70" Padding="15,8">
                                    <Label Text="{Binding BottomGuideName}" FontSize="15" TextColor="#1C1B1F" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding BottomGuideSize, StringFormat='{0:F0} мм'}" FontSize="15" TextColor="#1C1B1F" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                    <Label Grid.Column="2" Text="{Binding BottomGuideCount}" FontSize="15" TextColor="#1C1B1F" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                </Grid>
                                <BoxView HeightRequest="1" Color="#F0F0F0" Margin="15,0"/>

                                <Grid ColumnDefinitions="*, 70, 70" Padding="15,8">
                                    <Label Text="{Binding VerticalSlimName}" FontSize="15" TextColor="#1C1B1F" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding VerticalSlimSize, StringFormat='{0:F0} мм'}" FontSize="15" TextColor="#1C1B1F" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                    <Label Grid.Column="2" Text="{Binding VerticalSlimCount}" FontSize="15" TextColor="#1C1B1F" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                </Grid>
                                <BoxView HeightRequest="1" Color="#F0F0F0" Margin="15,0"/>

                                <Grid ColumnDefinitions="*, 70, 70" Padding="15,8">
                                    <Label Text="{Binding NarrowFrameName}" FontSize="15" TextColor="#1C1B1F" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding NarrowFrameSize, StringFormat='{0:F0} мм'}" FontSize="15" TextColor="#1C1B1F" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                    <Label Grid.Column="2" Text="{Binding NarrowFrameCount}" FontSize="15" TextColor="#1C1B1F" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                </Grid>
                                <BoxView HeightRequest="1" Color="#F0F0F0" Margin="15,0"/>

                                <Grid ColumnDefinitions="*, 70, 70" Padding="15,8">
                                    <Label Text="{Binding WideFrameName}" FontSize="15" TextColor="#1C1B1F" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding WideFrameSize, StringFormat='{0:F0} мм'}" FontSize="15" TextColor="#1C1B1F" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                    <Label Grid.Column="2" Text="{Binding WideFrameCount}" FontSize="15" TextColor="#1C1B1F" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                </Grid>
                                <BoxView HeightRequest="1" Color="#F0F0F0" Margin="15,0"/>

                                <Grid ColumnDefinitions="*, 70, 70" Padding="15,8">
                                    <Label Text="{Binding MiddleFrameName}" FontSize="15" TextColor="#1C1B1F" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding MiddleFrameSize, StringFormat='{0:F0} мм'}" FontSize="15" TextColor="#1C1B1F" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                    <Label Grid.Column="2" Text="{Binding MiddleFrameCount}" FontSize="15" TextColor="#1C1B1F" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                </Grid>
                            </VerticalStackLayout>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="#CAC4D0"/>
                        <VerticalStackLayout Padding="15,10" Spacing="5">
                            <Label Text="Комментарий" 
                                   FontSize="12" 
                                   TextColor="#6750A4" 
                                   FontAttributes="Bold"/>

                            <Frame Padding="10,5" 
                                   BorderColor="#E0E0E0" 
                                   CornerRadius="5" 
                                   HasShadow="False" 
                                   BackgroundColor="#FAFAFA">
                                <Editor Text="{Binding Furniture.Comment}" 
                                        Placeholder="Введите дополнительную информацию..." 
                                        TextColor="#1C1B1F" 
                                        FontSize="15"
                                        AutoSize="TextChanges"
                                        HeightRequest="80" 
                                        Keyboard="Text"/>
                            </Frame>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentView>