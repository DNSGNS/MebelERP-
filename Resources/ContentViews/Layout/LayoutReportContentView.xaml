<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MyApp1"
             x:Class="MyApp1.LayoutReportContentView"
             x:Name="thisPage">
    <ContentView.Resources>
        <local:AreaConverter x:Key="AreaConverter" />
    </ContentView.Resources>

    <Grid RowDefinitions="*, Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="15">

                <Label Text="ИТОГОВЫЙ ОТЧЁТ" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       TextColor="#312E35"/>

                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="True" BorderColor="Transparent" Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Результаты раскроя" TextColor="#6750A4" FontAttributes="Bold" FontSize="16"/>
                        <BoxView HeightRequest="1" Color="#E6E0E9"/>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Размер Стола (мм)" TextColor="#49454F"/>
                            <HorizontalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{Binding Settings.SheetLength}" FontAttributes="Bold" TextColor="#1C1B1F"/>
                                <Label Text="x" TextColor="#1C1B1F"/>
                                <Label Text="{Binding Settings.SheetWidth}" FontAttributes="Bold" TextColor="#1C1B1F"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Площадь 1 Стола" TextColor="#49454F"/>
                            <Label Grid.Column="1" 
                                   Text="{Binding Settings, Converter={StaticResource AreaConverter}, StringFormat='{0:F2} м²'}" 
                                   FontAttributes="Bold" TextColor="#1C1B1F"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F3EDF7" Margin="0,5"/>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Использовано Столов" TextColor="#49454F"/>
                            <Label Grid.Column="1" Text="{Binding LastResult.TotalSheets}" 
                                   FontAttributes="Bold" TextColor="#6750A4" FontSize="16"/>
                        </Grid>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Общая площадь материала" TextColor="#49454F"/>
                            <Label Grid.Column="1" 
                                   Text="{Binding LastResult.TotalSheetArea, Converter={StaticResource AreaConverter}, StringFormat='{0:F2} м²'}" 
                                   FontAttributes="Bold" TextColor="#1C1B1F"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F3EDF7" Margin="0,5"/>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Количество деталей" TextColor="#49454F"/>
                            <Label Grid.Column="1" Text="{Binding LastResult.TotalPartsCount}" 
                                   FontAttributes="Bold" TextColor="#1C1B1F"/>
                        </Grid>

                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Площадь деталей" TextColor="#49454F"/>
                            <Label Grid.Column="1" 
                                   Text="{Binding LastResult.TotalPartsArea, Converter={StaticResource AreaConverter}, StringFormat='{0:F2} м²'}" 
                                   FontAttributes="Bold" TextColor="#1C1B1F"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="True" BorderColor="Transparent" Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Список деталей" TextColor="#6750A4" FontAttributes="Bold" FontSize="16"/>

                        <Grid ColumnDefinitions="25, 90, *, 70, *, 40" Padding="5,0">
                            <Label Grid.Column="0" Text="№" FontSize="11" FontAttributes="Bold" TextColor="#79747E" HorizontalOptions="Center"/>
                            <Label Grid.Column="1" Text="РАЗМЕР" FontSize="11" FontAttributes="Bold" TextColor="#79747E" HorizontalOptions="Center"/>

                            <Label Grid.Column="2" Text="ЦВЕТ" FontSize="11" FontAttributes="Bold" TextColor="#79747E" 
                                   HorizontalOptions="Center"
                                   IsVisible="{Binding BindingContext.IsColorVisible, Source={x:Reference thisPage}}"/>

                            <Label Grid.Column="3" Text="КРАЙ" FontSize="11" FontAttributes="Bold" TextColor="#79747E" HorizontalOptions="Center"/>
                            <Label Grid.Column="4" Text="ФРЕЗА" FontSize="11" FontAttributes="Bold" TextColor="#79747E" HorizontalOptions="Center"/>

                            <Label Grid.Column="5" Text="КОЛ-ВО" FontSize="11" FontAttributes="Bold" TextColor="#79747E" HorizontalOptions="Center"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#E6E0E9" Margin="0,0,0,5"/>

                        <CollectionView ItemsSource="{Binding DetailsForm.Details}" HeightRequest="300">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="25, 90, *, 70, *, 40" Padding="0,5">
                                        <Label Grid.Column="0" Text="{Binding Id}" VerticalOptions="Start" HorizontalTextAlignment="Center" TextColor="#49454F" FontSize="12"/>

                                        <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Start" Spacing="2">
                                            <Label Text="{Binding Length}" TextColor="#1C1B1F" FontSize="13" FontAttributes="Bold"/>
                                            <Label Text="x" TextColor="#79747E" FontSize="12"/>
                                            <Label Text="{Binding Width}" TextColor="#1C1B1F" FontSize="13" FontAttributes="Bold"/>
                                        </HorizontalStackLayout>

                                        <Label Grid.Column="2" Text="{Binding Color}" 
                                               VerticalOptions="Start" HorizontalTextAlignment="Center" TextColor="#1C1B1F"
                                               Margin="5,0"
                                               IsVisible="{Binding BindingContext.IsColorVisible, Source={x:Reference thisPage}}"/>

                                        <Border Grid.Column="3" 
                                                BackgroundColor="#EADDFF" 
                                                HorizontalOptions="Center" 
                                                VerticalOptions="Start"
                                                Padding="5,2" 
                                                StrokeShape="RoundRectangle 4" 
                                                StrokeThickness="0">
                                            <Label Text="{Binding SelectedEdgeType}" FontSize="10" TextColor="#6750A4" HorizontalTextAlignment="Center"/>
                                        </Border>

                                        <Label Grid.Column="4" 
                                               Text="{Binding MillingText}" 
                                               FontSize="11" 
                                               VerticalOptions="Start" 
                                               HorizontalTextAlignment="Center"
                                               TextColor="#1C1B1F" 
                                               LineBreakMode="TailTruncation" 
                                               Margin="5,0"/>

                                        <Label Grid.Column="5" Text="{Binding Count}" VerticalOptions="Start" HorizontalTextAlignment="Center" TextColor="#1C1B1F" FontAttributes="Bold"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <VerticalStackLayout x:Name="ReportSheetsContainer" Spacing="15" Padding="0,10,0,0">
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <Frame Grid.Row="1" 
               BackgroundColor="White" 
               Padding="20,15" 
               HasShadow="True" 
               CornerRadius="0"
               BorderColor="#E6E0E9">
            <Button Text="СОХРАНИТЬ РАСЧЕТ И ВЫЙТИ" 
                    Clicked="OnSaveReportClicked"
                    BackgroundColor="#6750A4" 
                    TextColor="White" 
                    FontAttributes="Bold"
                    HeightRequest="50"/>
        </Frame>
    </Grid>
</ContentView>