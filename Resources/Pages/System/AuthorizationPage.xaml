<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyApp1.AuthorizationPage"
             Title="Авторизация"
             BackgroundColor="#F0F0F0">

    <Grid>
        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout Padding="30" Spacing="20" MaximumWidthRequest="450">

                <Label Text="ВХОД В СИСТЕМУ" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center" 
                       TextColor="#2B3C51" 
                       Margin="0,0,0,10"/>

                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="True" Padding="20">
                    <VerticalStackLayout Spacing="15">

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Логин" TextColor="#555555" FontSize="14"/>
                            <Entry x:Name="UsernameEntry" 
                                   Placeholder="Введите логин"
                                   TextColor="#2B3C51"
                                   BackgroundColor="#F5F5F5"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Пароль" TextColor="#555555" FontSize="14"/>
                            <Entry x:Name="PasswordEntry" 
                                   IsPassword="True"
                                   Placeholder="••••••••"
                                   TextColor="#2B3C51"
                                   BackgroundColor="#F5F5F5"/>
                        </VerticalStackLayout>

                        <Label x:Name="ErrorLabel" 
                               TextColor="#C62828" 
                               FontSize="13" 
                               HorizontalOptions="Center" 
                               IsVisible="False" 
                               HorizontalTextAlignment="Center"/>

                        <Button x:Name="LoginBtn"
                                Text="ВОЙТИ" 
                                Clicked="OnLoginClicked"
                                BackgroundColor="#2B3C51" 
                                TextColor="White" 
                                HeightRequest="55" 
                                CornerRadius="8" 
                                FontAttributes="Bold"
                                Margin="0,10,0,0"/>

                    </VerticalStackLayout>
                </Frame>

                <Label Text="© 2025 FASADim" 
                       HorizontalOptions="Center" 
                       TextColor="Gray" 
                       FontSize="12"/>

            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="LoadingOverlay" IsVisible="False" BackgroundColor="#80000000">
            <VerticalStackLayout VerticalOptions="Center" Spacing="10">
                <ActivityIndicator IsRunning="True" Color="White" HeightRequest="50" WidthRequest="50"/>
                <Label Text="Проверка данных..." TextColor="White" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>