<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:local="clr-namespace:MyApp1"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyApp1.ObjectWorkshopEditorPage"
             Title="{Binding ObjectName}"
             BackgroundColor="#FBF8FF"
             Padding="0">

        <Grid RowDefinitions="Auto, * , Auto">

        <ScrollView Grid.Row="0" 
            Orientation="Horizontal" 
            HorizontalScrollBarVisibility="Never" 
            BackgroundColor="#2B3C51"
            HeightRequest="60">

            <HorizontalStackLayout Padding="10,0" Spacing="5" VerticalOptions="Center">
                <HorizontalStackLayout.Resources>
                    <Style TargetType="Button">
                        <Setter Property="BackgroundColor" Value="Transparent" />
                        <Setter Property="TextColor" Value="White" />
                        <Setter Property="FontAttributes" Value="Bold" />
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="Padding" Value="15,0" />
                        <Setter Property="HeightRequest" Value="50" />
                        <Setter Property="MinimumWidthRequest" Value="100" />
                        <Setter Property="BorderWidth" Value="0" />
                        <Setter Property="BorderColor" Value="Transparent" />
                        <Setter Property="CornerRadius" Value="0" />
                    </Style>
                </HorizontalStackLayout.Resources>

                <Button x:Name="btnCutting" Text="Раскрой" Clicked="OnTabClicked" CommandParameter="Cutting" />
                <Button x:Name="btnLayout" Text="Раскладка" Clicked="OnTabClicked" CommandParameter="Layout" />
                <Button x:Name="btnDoors" Text="Двери/Профили" Clicked="OnTabClicked" CommandParameter="Doors" />
                <Button x:Name="btnEdge" Text="Кромка" Clicked="OnTabClicked" CommandParameter="Edge" />
            </HorizontalStackLayout>
        </ScrollView>

        <ContentView Grid.Row="1"
                     x:Name="ContentContainer"
                     VerticalOptions="FillAndExpand"
                     HorizontalOptions="Fill" />

        <Grid Grid.RowSpan="3"
          BackgroundColor="#80000000"
          IsVisible="{Binding IsBusy}"
          InputTransparent="False">
            <VerticalStackLayout VerticalOptions="Center" 
                             HorizontalOptions="Center" 
                             Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                               Color="White" 
                               HeightRequest="60" 
                               WidthRequest="60"/>
                <Label Text="Загрузка задач..." 
                   TextColor="White" 
                   FontSize="16"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>