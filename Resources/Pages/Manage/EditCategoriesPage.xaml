<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MyApp1"
             x:Class="MyApp1.EditCategoriesPage"
             Title="Редактор категорий"
             BackgroundColor="#F0F0F0">

    <Grid RowDefinitions="Auto, *">
        <Grid Grid.Row="0" BackgroundColor="White" Padding="15">
            <Label Text="Управление типами затрат" FontAttributes="Bold" FontSize="18" TextColor="#2B3C51" VerticalOptions="Center"/>
            <Button Text="+ Добавить новый тип" 
                    Clicked="OnAddClicked"
                    HorizontalOptions="End" 
                    BackgroundColor="#6750A4" TextColor="White" FontSize="12" CornerRadius="8" HeightRequest="35"/>
        </Grid>

        <CollectionView Grid.Row="1" x:Name="CategoriesList" SelectionMode="None" Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:ExpenseCategory">
                    <Border StrokeThickness="0" BackgroundColor="White" Margin="0,4" Padding="10" StrokeShape="RoundRectangle 8">
                        <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="10">

                            <Label Grid.Column="0" Text="{Binding Name}" 
                                   VerticalOptions="Center" TextColor="#2B3C51" FontSize="14"/>

                            <Button Grid.Column="1" Text="✎" 
                                    Clicked="OnEditClicked" CommandParameter="{Binding .}"
                                    BackgroundColor="#E3F2FD" TextColor="#1565C0" 
                                    HeightRequest="35" WidthRequest="35" CornerRadius="17" Padding="0"/>

                            <Button Grid.Column="2" Text="✕" 
                                    Clicked="OnDeleteClicked" CommandParameter="{Binding .}"
                                    BackgroundColor="#FFEBEE" TextColor="#C62828" 
                                    HeightRequest="35" WidthRequest="35" CornerRadius="17" Padding="0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator x:Name="LoadingSpinner" IsRunning="False" IsVisible="False" 
                           HorizontalOptions="Center" VerticalOptions="Center" Grid.RowSpan="2" Color="#6750A4"/>
    </Grid>
</ContentPage>