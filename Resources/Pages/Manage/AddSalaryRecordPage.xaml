<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MyApp1"
             x:Class="MyApp1.AddSalaryRecordPage"
             Title="Запись работы"
             BackgroundColor="#F0F0F0">

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:MaterialNameConverter x:Key="MaterialConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="15">

                <Frame BackgroundColor="White" Padding="15" CornerRadius="10" HasShadow="True">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="ОСНОВНАЯ ИНФОРМАЦИЯ" FontAttributes="Bold" TextColor="#2B3C51" Margin="0,0,0,5"/>

                        <Label Text="Сотрудник:" TextColor="#555555" FontSize="12"/>
                        <Entry Text="{Binding WorkerName}" IsReadOnly="True" BackgroundColor="#F5F5F5" TextColor="#2B3C51"/>

                        <Label Text="Дата выполнения:" TextColor="#555555" FontSize="12"/>
                        <DatePicker Date="{Binding DatePerformed}" TextColor="#2B3C51" MinimumHeightRequest="45"/>

                        <Border Stroke="#2B3C51" StrokeThickness="1" StrokeShape="RoundRectangle 8" BackgroundColor="#EDF7FF" Padding="10" Margin="0,5">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Проект (обязательно):" TextColor="#2B3C51" FontAttributes="Bold" FontSize="12"/>
                                <Picker ItemsSource="{Binding AllProjects}" 
                                        ItemDisplayBinding="{Binding Name}"
                                        SelectedItem="{Binding SelectedProject}"
                                        Title="Выберите проект"
                                        TitleColor="Gray"
                                        TextColor="#2B3C51"
                                        BackgroundColor="White"/>

                                <Label Text="Материал:" TextColor="#2B3C51" FontAttributes="Bold" FontSize="12"/>
                                <Picker ItemsSource="{Binding Materials}" 
                                        SelectedItem="{Binding SelectedMaterial}"
                                        Title="Выберите материал"
                                        TitleColor="Gray"
                                        TextColor="#2B3C51"
                                        BackgroundColor="White">
                                    <Picker.ItemDisplayBinding>
                                        <Binding Path="." Converter="{StaticResource MaterialConverter}" />
                                    </Picker.ItemDisplayBinding>
                                </Picker>
                            </VerticalStackLayout>
                        </Border>

                        <HorizontalStackLayout Spacing="20">
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="Замер" VerticalOptions="Center" TextColor="#333333"/>
                                <CheckBox IsChecked="{Binding IsMeasurement}" Color="#6750A4"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="Установка" VerticalOptions="Center" TextColor="#333333"/>
                                <CheckBox IsChecked="{Binding IsInstallation}" Color="#6750A4"/>
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <Frame BackgroundColor="White" Padding="15" CornerRadius="10" HasShadow="True">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="ОБЪЕМЫ РАБОТ" FontAttributes="Bold" TextColor="#2B3C51" Margin="0,0,0,5"/>

                        <Grid ColumnDefinitions="*, 100" ColumnSpacing="10">
                            <Label Text="Пила (м2)" VerticalOptions="Center" TextColor="#333333"/>
                            <Entry Grid.Column="1" Text="{Binding Saw}" Keyboard="Numeric" TextColor="#2B3C51" HorizontalTextAlignment="End" Focused="OnEntryFocused"/>
                        </Grid>

                        <Grid ColumnDefinitions="*, 100" ColumnSpacing="10">
                            <Label Text="Кромление (м)" VerticalOptions="Center" TextColor="#333333"/>
                            <Entry Grid.Column="1" Text="{Binding Edging}" Keyboard="Numeric" TextColor="#2B3C51" HorizontalTextAlignment="End" Focused="OnEntryFocused"/>
                        </Grid>

                        <Grid ColumnDefinitions="*, 100" ColumnSpacing="10">
                            <Label Text="Присадка (м2)" VerticalOptions="Center" TextColor="#333333"/>
                            <Entry Grid.Column="1" Text="{Binding Additive}" Keyboard="Numeric" TextColor="#2B3C51" HorizontalTextAlignment="End" Focused="OnEntryFocused"/>
                        </Grid>

                        <Grid ColumnDefinitions="*, 100" ColumnSpacing="10">
                            <Label Text="Двери-купе (пол.)" VerticalOptions="Center" TextColor="#333333"/>
                            <Entry Grid.Column="1" Text="{Binding DoorCanvas}" Keyboard="Numeric" TextColor="#2B3C51" HorizontalTextAlignment="End" Focused="OnEntryFocused"/>
                        </Grid>

                        <Grid ColumnDefinitions="*, 100" ColumnSpacing="10">
                            <Label Text="Упаковка (м2)" VerticalOptions="Center" TextColor="#333333"/>
                            <Entry Grid.Column="1" Text="{Binding Packaging}" Keyboard="Numeric" TextColor="#2B3C51" HorizontalTextAlignment="End" Focused="OnEntryFocused"/>
                        </Grid>

                        <Grid ColumnDefinitions="*, 100" ColumnSpacing="10">
                            <Label Text="Шлифовка (м2)" VerticalOptions="Center" TextColor="#333333"/>
                            <Entry Grid.Column="1" Text="{Binding GrindingSoap}" Keyboard="Numeric" TextColor="#2B3C51" HorizontalTextAlignment="End" Focused="OnEntryFocused"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame BackgroundColor="White" Padding="15" CornerRadius="10" HasShadow="True">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="ДОПОЛНИТЕЛЬНО" FontAttributes="Bold" TextColor="#2B3C51"/>
                        <Grid ColumnDefinitions="*, 100" ColumnSpacing="10">
                            <Label Text="Доп (Руб)" VerticalOptions="Center" TextColor="#333333"/>
                            <Entry Grid.Column="1" Text="{Binding Additionally}" Keyboard="Numeric" TextColor="#2B3C51" HorizontalTextAlignment="End" Focused="OnEntryFocused"/>
                        </Grid>
                        <Editor Text="{Binding Comment}" Placeholder="Комментарий..." TextColor="#2B3C51" PlaceholderColor="Gray" HeightRequest="80" Focused="OnEntryFocused"/>

                        <HorizontalStackLayout HorizontalOptions="End" Spacing="10">
                            <Label Text="ИТОГО:" FontAttributes="Bold" VerticalOptions="Center" TextColor="#333333"/>
                            <Label Text="{Binding TotalSalary, StringFormat='{0:N2} ₽'}" FontSize="20" TextColor="#2E7D32" FontAttributes="Bold"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <Button Text="СОХРАНИТЬ" Clicked="OnSaveClicked" BackgroundColor="#2B3C51" TextColor="White" HeightRequest="55" CornerRadius="10" Margin="0,10,0,20"/>
            </VerticalStackLayout>
        </ScrollView>

        <Grid BackgroundColor="#AA000000" IsVisible="{Binding IsBusy}" InputTransparent="False">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" HeightRequest="60" WidthRequest="60"/>
                <Label Text="Подождите..." TextColor="White" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>