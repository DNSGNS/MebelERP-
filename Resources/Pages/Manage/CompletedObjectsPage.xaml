<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MyApp1"
             x:Class="MyApp1.CompletedObjectsPage"
             Title="Объекты проекта"
             BackgroundColor="#F0F0F0">

    <ScrollView Padding="20">
        <VerticalStackLayout BindableLayout.ItemsSource="{Binding ProjectObjects}" Spacing="15">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="local:CompletedProjectObject">
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="White" Padding="15">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding OrderName}" FontSize="18" FontAttributes="Bold" TextColor="#2B3C51"/>

                            <BoxView HeightRequest="1" Color="#EEEEEE"/>

                            <Grid ColumnDefinitions="*, *, *, *" ColumnSpacing="10">
                                <Button Grid.Column="0" Text="📄 Расчет" BackgroundColor="#607D8B" Clicked="OnReportDoorSlimLineClicked" CommandParameter="{Binding .}"/>
                                <Button Grid.Column="1" Text="✂️ ЛДСП" BackgroundColor="#4CAF50" Clicked="OnCuttingReportCorpusLDSPClicked" CommandParameter="{Binding .}"/>
                                <Button Grid.Column="2" Text="✂️ Ф_АГТ" BackgroundColor="#4CAF50" Clicked="OnCuttingReportFasadsAGTClicked" CommandParameter="{Binding .}"/>
                                <Button Grid.Column="3" Text="✂️ Ф_ЛДСП" BackgroundColor="#4CAF50" Clicked="OnCuttingReportFasadsLDSPClicked" CommandParameter="{Binding .}"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>