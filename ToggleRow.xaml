<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyApp1.ToggleRow"
             x:Name="root">
    <Grid ColumnDefinitions="*, 52" HeightRequest="44"
          BackgroundColor="Transparent">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding ToggleCommand, Source={x:Reference root}}"
                                  CommandParameter="{Binding CommandParam, Source={x:Reference root}}"/>
        </Grid.GestureRecognizers>

        <Label Grid.Column="0"
               Text="{Binding Label, Source={x:Reference root}}"
               VerticalOptions="Center"
               TextColor="#1C1B1F"
               FontSize="15"/>

        <!-- Track -->
        <Border Grid.Column="1"
                WidthRequest="48" HeightRequest="28"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="0"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <Border.Triggers>
                <DataTrigger TargetType="Border"
                             Binding="{Binding IsOn, Source={x:Reference root}}" Value="True">
                    <Setter Property="BackgroundColor" Value="#6750A4"/>
                </DataTrigger>
                <DataTrigger TargetType="Border"
                             Binding="{Binding IsOn, Source={x:Reference root}}" Value="False">
                    <Setter Property="BackgroundColor" Value="#CAC4D0"/>
                </DataTrigger>
            </Border.Triggers>

            <!-- Thumb -->
            <Border WidthRequest="22" HeightRequest="22"
                    StrokeShape="RoundRectangle 11"
                    StrokeThickness="0"
                    BackgroundColor="White"
                    VerticalOptions="Center">
                <Border.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding IsOn, Source={x:Reference root}}" Value="True">
                        <Setter Property="HorizontalOptions" Value="End"/>
                        <Setter Property="Margin" Value="0,0,2,0"/>
                    </DataTrigger>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding IsOn, Source={x:Reference root}}" Value="False">
                        <Setter Property="HorizontalOptions" Value="Start"/>
                        <Setter Property="Margin" Value="2,0,0,0"/>
                    </DataTrigger>
                </Border.Triggers>
            </Border>
        </Border>
    </Grid>
</ContentView>